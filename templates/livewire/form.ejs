<?php
<%
const table = definition.table;
const modelClass = helpers.naming.modelClass(table);
const fks = helpers.item.foreignKeysMap(definition);
const inputs = [];
const rules = {};
definition.columns.forEach((column) => {
    helpers.column.inputsByColumn(column, fks)
        .forEach((input) => inputs.push(input));
    const columnRules = helpers.column.rules(column);
    if (columnRules.length) {
        rules[column.name] = columnRules.join('|');
    }
});
const defaultInputValues = helpers.column.defaultInputValues(definition.columns, fks);
%>
namespace App\Livewire\Generathor\Forms;

use Livewire\Attributes\Validate;
use Livewire\Form;
use App\Models\<%= modelClass %>;

class <%= modelClass %>Form extends Form
{
    public ?<%= modelClass %> $record = null;
<% for(const input of inputs) { %>
    #[Validate('<%= rules[input.name] %>')]
    public $<%= input.name %> = <%- 
        input.name in defaultInputValues ? 
            typeof defaultInputValues[input.name] === 'string' ? 
                `'${defaultInputValues[input.name]}'` :
                defaultInputValues[input.name]:
            'null' %>;
<% } %>
    public function setRecord(<%= modelClass %> $record)
    {
        $this->record = $record;<% for(const input of inputs) { %>
        $this-><%= input.name %> = $record-><%= input.name %>;<% } %>
    }

    public function save()
    {
        $this->validate();
        if (!$this->record) {
            $this->record = new <%= modelClass %>();
        }<% for(const input of inputs) { %>
        $this->record-><%= input.name %> = $this-><%= input.name %>;<% } %>
        $this->record->save();
    }
}
<?php
namespace App\Livewire\Generathor\Components;

use Livewire\Component;
use Livewire\Attributes\Url;
use Livewire\Attributes\Computed;

/**
 * @property $form
 * @property $record
 */
abstract class EditFormComponent extends Component
{
    use WithMessages;
    use WithErrorHandler;

    #[Url]
    public $return_url = '';

    #[Computed]
    public function redirectUrl()
    {
        return $this->return_url ?: route($this->routeName(), [
            'record' => $this->record->getRouteKey(),
        ]);
    }

    public function rendering($view)
    {
        $view->title($this->titleComponent());
    }

    public function mount() {
        $this->form->setRecord($this->record);
    }

    public function save()
    {
        try {
            $this->form->save();
            $this->withSuccessMessage(__('Record updated successfully'));
            $this->redirect($this->redirectUrl(), navigate: true);
        } catch (\Exception $e) {
            $this->handleError($e);
        }
    }

    abstract protected function titleComponent(): string;

    abstract protected function routeName(): string;
}
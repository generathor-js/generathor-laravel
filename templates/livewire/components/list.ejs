<?php
namespace App\Livewire\Generathor\Components;

use Livewire\Attributes\Computed;
use Livewire\Component;
use Livewire\WithPagination;

/**
 * @property $form
 * @property $record
 */
abstract class ListComponent extends Component
{
    use WithPagination;
    use WithFilterableList;
    use WithMessages;
    use WithErrorHandler;

    public $currentId = null;
    public $showDeleteModal = false;

    #[Computed]
    public function items()
    {
        $modelClass = $this->modelClass();

        return $modelClass::query()
            ->sortable([
                $this->sort => $this->direction,
            ])
            ->filter($this->filters)
            ->paginate(20);
    }

    public function rendering($view)
    {
        $view->title($this->titleComponent());
    }

    public function boot() {
        $this->bootFilters();
    }

    public function delete()
    {
        try {
            $modelClass = $this->modelClass();
            $record = $modelClass::findOrFail($this->currentId);
            $record->delete();
            $this->withSuccessMessage(__('Record deleted successfully'));
        } catch (\Exception $e) {
            $this->handleError($e);
        }
        $this->setCurrentId(null);
    }

    public function setCurrentId($id)
    {
        $this->currentId = $id;
        $this->showDeleteModal = boolval($id);
    }

    public function save()
    {
        try {
            $this->form->save();
            $this->withSuccessMessage(__('Record created successfully'));
            $this->redirectRoute($this->routeName(), [
                'record' => $this->form->record->getRouteKey(),
            ], navigate: true);
        } catch (\Exception $e) {
            $this->handleError($e);
        }
    }

    abstract protected function modelClass(): string;

    abstract protected function routeName(): string;

    abstract protected function titleComponent(): string;
}
const homeRoute = configuration.homeRoute();
const table = definition.table;
const modelClass = helpers.naming.modelClass(table);
const modelLabel = helpers.naming.listLabel(table);
const context = helpers.naming.context(table);
const fks = helpers.item.foreignKeysMap(definition);
const filterFormInputs = [];
const createFormInputs = [];
const createFormRules = {};
const columns = definition.columns.map((column) => {
    let type = column.type;
    let relation = null;
    if (fks[column.name]) {
        type = 'record';
        relation = {
            attribute: helpers.naming.relationAttribute(fks[column.name], table),
            context: helpers.naming.context(fks[column.name].on.table),
        };
    }
    helpers.column.inputsByColumn(column, fks, true).forEach((input) => filterFormInputs.push(input));
    helpers.column.inputsByColumn(column, fks).forEach((input) => createFormInputs.push(input));

    return {
        relation,
        type,
        name: column.name,
        label: helpers.naming.columnLabel(column),
        nullable: column.nullable,
    };
});
const defaultInputValues = helpers.column.defaultInputValues(definition.columns, fks);

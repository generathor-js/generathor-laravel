<%
const homeRoute = configuration.homeRoute();
const table = definition.table;
const modelClass = helpers.naming.modelClass(table);
const modelLabel = helpers.naming.listLabel(table);
const context = helpers.naming.context(table);
const relatedContext = helpers.naming.context(relatedItem.table);
const relatedLabel = helpers.naming.relationLabel(relation, table);
const fks = helpers.item.foreignKeysMap(definition);
const relatedFks = helpers.item.foreignKeysMap(relatedItem);
const relationAttributName = helpers.naming.relationAttribute(relation, table);
const relatedModelClass = helpers.naming.modelClass(relation.on.table);
const capitalizedRelationAttribute = helpers.naming.capitalizedRelationAttribute(relation, table);
const references = relation.references.reduce((acc, reference, index) => {
    acc[reference] = relation.columns[index];
    return acc;
}, {});
const createFormInputs = [];
const attachFormInputs = [];
const columns = relatedItem.columns.map((column) => {
    let type = column.type;
    let relationAttribute = null;
    if (relatedFks[column.name]) {
        type = 'record';
        relationAttribute = helpers.naming.relationAttribute(relatedFks[column.name], relatedItem.table);
    }
    helpers.column.inputsByColumn(column, relatedFks)
        .forEach((input) => createFormInputs.push(input));

    return {
        relationAttribute,
        type,
        name: column.name,
        label: helpers.naming.columnLabel(column),
        nullable: column.nullable,
        context: relatedFks[column.name] ? helpers.naming.context(relatedFks[column.name].on.table) : null,
    };
});
const inputsByColumn = (column) => {
    if (column.autoincrement) {
        return [{
            type: 'record',
            name: column.name,
            label: helpers.naming.columnLabel(column),
            data: {
                context: helpers.naming.searchContext(relatedItem.table),
            },
        }];
    }

    return helpers.column.inputsByColumn(column, fks);
}
const keyMap = relatedItem.primaryKey.columns.reduce((acc, key) => {
    acc[key] = true;
    return acc;
}, {});
relatedItem.columns.forEach((column) => {
    if (!keyMap[column.name]) {
        return;
    }
    inputsByColumn(column).forEach((input) => attachFormInputs.push(input));
});
const tabs = definition.relations.map((relation) => {
    return {
        label: helpers.naming.relationLabel(relation, definition.table),
        attribute: helpers.naming.capitalizedRelationAttribute(relation, definition.table),
    };
});
const defaultInputValues = helpers.column.defaultInputValues(relatedItem.columns, relatedFks);

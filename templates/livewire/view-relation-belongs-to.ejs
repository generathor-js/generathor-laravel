use App\Models\<%= modelClass %>;
use App\Livewire\Generathor\Components\RelatedViewComponent;
use App\Livewire\Generathor\Forms\<%= relatedModelClass %>Form;
use App\Livewire\Generathor\Forms\Attach<%= relatedModelClass %>Form;

new class extends RelatedViewComponent
{
    public <%= modelClass %> $record;

    public <%= relatedModelClass %>Form $form;

    public Attach<%= relatedModelClass %>Form $attachForm;

    protected function relation()
    {
        return $this->record-><%= relationAttributName %>;
    }

    protected function relationReferences(): array
    {
        return [<% for(const column in references) { %>
            '<%= column %>' => '<%= references[column] %>',<% } %>
        ];
    }

    protected function titleComponent(): string
    {
       return $this->record->getRecordLabel();
    }
} ?>

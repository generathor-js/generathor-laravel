Route::get('search/{context}', function ($context) {
    $modelClass = 'App\\Models\\' . str($context)->studly();

    if (!class_exists($modelClass) || !method_exists($modelClass, 'search')) {
        return [];
    }

    $id = request('id');
    $id = is_string($id) && !empty($id) ? $id : null;

    if ($id) {
        $item = $modelClass::find($id);

        return $item ? [
            [
                'id' => $item->id,
                'label' => $item->getRecordLabel()
            ]
        ] : [];
    }

    $query = request('q');
    $query = is_string($query) && !empty($query) ? $query : '';

    return $modelClass::search($query)
        ->limit(10)
        ->get()
        ->map(fn($item) => [
            'id' => $item->id,
            'label' => $item->getRecordLabel(),
        ]);
})->name('generathor.search');
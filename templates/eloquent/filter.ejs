<?php
<%
const table = definition.table;
const modelClass = helpers.naming.modelClass(table) + 'Filter';
const filterMaps = {
    int: 'range',
    float: 'range',
    boolean: 'boolean',
    string: 'string',
    date: 'range',
};
const primaryKeyMap = helpers.item.primaryKeyMap(definition);
const fks = helpers.item.foreignKeysMap(definition);

const filters = definition.columns.map(column => {
    let type = filterMaps[column.type] ?? 'same';
    if (primaryKeyMap[column.name] || fks[column.name]) {
        type = 'same';
    }

    return {
        type,
        name: column.name,
        attribute: helpers.naming.columnAttribute(column),
    };
});
%>
namespace App\ModelFilters;

use EloquentFilter\ModelFilter;

/**
 * Automatically generated by Generathor
 *
 * Class <%= modelClass %>
 */
class <%= modelClass %> extends ModelFilter
{
    protected $drop_id = false;
<% filters.forEach(function(filter) { %><% if (filter.type === 'same') { %>
    public function <%= filter.attribute %>($value)
    {
        return $this->where('<%=  filter.name %>', $value);
    }<% } else if (filter.type === 'range') { %>
    public function <%= filter.attribute %>From($value)
    {
        return $this->where('<%=  filter.name %>', '>=', $value);
    }

    public function <%= filter.attribute %>To($value)
    {
        return $this->where('<%=  filter.name %>', '<=', $value);
    }<% } else if (filter.type === 'boolean') { %>
    public function <%= filter.attribute %>($value)
    {
        if ($value === '1') {
            return $this->where('<%=  filter.name %>', true);
        }

        return $this->where(function ($query) {
            $query->whereNull('<%=  filter.name %>')
                ->orWhere('<%=  filter.name %>', false);
        });
    }<% } else if (filter.type === 'string') { %>
    public function <%= filter.attribute %>($value)
    {
        return $this->where('<%=  filter.name %>', 'LIKE', "%$value%");
    }<% } %>
<% }); %>}